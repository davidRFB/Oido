{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "default": {
        "messages": {
          ".read": true,
          ".write": "!newData.exists()",
          "$msgId": {
            ".write": "!data.exists() && newData.exists()",
            ".validate": "newData.hasChildren(['name', 'color', 'text', 'isFinal', 'timestamp'])",
            "name":      { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
            "color":     { ".validate": "newData.isString() && newData.val().matches(/^#[0-9a-fA-F]{6}$/)" },
            "text":      { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "isFinal":   { ".validate": "newData.isBoolean()" },
            "timestamp": { ".validate": "newData.isNumber() && newData.val() <= now + 60000" },
            "userId":    { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64" },
            "$other":    { ".validate": false }
          }
        },
        "clearedAt": {
          ".read": true,
          ".write": true,
          ".validate": "newData.isNumber()"
        },
        "presence": {
          ".read": true,
          "$pId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name', 'color', 'joinedAt'])",
            "name":     { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
            "color":    { ".validate": "newData.isString() && newData.val().matches(/^#[0-9a-fA-F]{6}$/)" },
            "joinedAt": { ".validate": "newData.isNumber()" },
            "userId":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64" },
            "$other":   { ".validate": false }
          }
        },
        "users": {
          ".read": true,
          "$userId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name', 'color', 'updatedAt'])",
            "name":      { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50" },
            "color":     { ".validate": "newData.isString() && newData.val().matches(/^#[0-9a-fA-F]{6}$/)" },
            "updatedAt": { ".validate": "newData.isNumber() && newData.val() <= now + 60000" },
            "voiceprint": {
              ".validate": "newData.hasChildren(['f0_mean', 'f0_stddev', 'f0_samples'])",
              "f0_mean":     { ".validate": "newData.isNumber() && newData.val() >= 50 && newData.val() <= 600" },
              "f0_stddev":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 200" },
              "f0_samples":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
              "enrolled_at": { ".validate": "newData.isNumber()" },
              "$other":      { ".validate": false }
            },
            "$other":    { ".validate": false }
          }
        },
        "devices": {
          ".read": true,
          "$userId": {
            ".write": true,
            "name":              { ".validate": "newData.isString() && newData.val().length <= 50" },
            "color":             { ".validate": "newData.isString() && newData.val().length <= 20" },
            "ua":                { ".validate": "newData.isString() && newData.val().length <= 500" },
            "platform":          { ".validate": "newData.isString() && newData.val().length <= 100" },
            "caps": {
              "speechApi":    { ".validate": "newData.isBoolean()" },
              "mediaDevices": { ".validate": "newData.isBoolean()" },
              "audioContext": { ".validate": "newData.isBoolean()" },
              "online":       { ".validate": "newData.isBoolean()" },
              "$other":       { ".validate": false }
            },
            "micPermission":     { ".validate": "newData.isString() && newData.val().length <= 20" },
            "unsupportedReason": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "readOnly":          { ".validate": "newData.isBoolean()" },
            "gateDegraded":      { ".validate": "newData.isBoolean()" },
            "monitorPeak":       { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
            "firstSeenAt":       { ".validate": "newData.isNumber()" },
            "lastSeenAt":        { ".validate": "newData.isNumber() && newData.val() <= now + 60000" },
            "recentErrors": {
              "$errorId": {
                ".validate": "newData.hasChildren(['code', 'at'])",
                "code":    { ".validate": "newData.isString() && newData.val().length <= 50" },
                "message": { ".validate": "newData.isString() && newData.val().length <= 500" },
                "at":      { ".validate": "newData.isNumber()" },
                "$other":  { ".validate": false }
              }
            },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
